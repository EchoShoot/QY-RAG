# =============================================================
# QY-RAG 环境配置（复制为 .env 后修改密码）
# =============================================================

RAGFLOW_IMAGE=qy-rag:v0.26.0
STACK_VERSION=8.11.3

# 密码，必须修改
ELASTIC_PASSWORD=change_me
MINIO_USER=qy_rag
MINIO_PASSWORD=change_me
REDIS_PASSWORD=change_me
PG_PASSWORD=change_me

ES_HOST=qy-es
ES_PORT=1200

MINIO_HOST=qy-minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

REDIS_HOST=qy-redis
REDIS_PORT=6379

PG_USER=postgres
PG_EXPOSE_PORT=5432
RAGFLOW_PG_DBNAME=qy_rag

SVR_WEB_HTTP_PORT=8513
SVR_WEB_HTTPS_PORT=443
SVR_HTTP_PORT=9380
ADMIN_SVR_HTTP_PORT=9381
SVR_MCP_PORT=9382
GO_HTTP_PORT=9384
GO_ADMIN_PORT=9383

# 单个容器最大内存限制，单位字节（约 8GB）
MEM_LIMIT=8073741824

TZ=Asia/Shanghai
REGISTER_ENABLED=1
DOC_BULK_SIZE=4
EMBEDDING_BATCH_SIZE=16
THREAD_POOL_MAX_WORKERS=128
DISABLE_PASSWORD_LOGIN=false
DOTNET_SYSTEM_GLOBALIZATION_INVARIANT=1
USE_DOCLING=false
